{
  "name": "profilesforagents",
  "productName": "Agent Profiles",
  "description": "Manage and switch context profiles for LLM CLI Agents",
  "author": "Parul Garg",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "bin": {
    "agent-profiles": "./bin/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "package": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.profilesforagents.app",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    }
  }
}
